# Copy this file to .env and fill the values you need.
# scripts/mr-slack/mr-slack.sh loads scripts/mr-slack/.env by default.

# Default target branch. You can override at runtime with:
#   slackmr --target-branch develop
MR_TARGET_BRANCH=main

# Optional. Normally auto-detected from git remote (strips oauth2:token@ and :port).
# Only set if detection is wrong:
# GITLAB_HOST=gitlab.vtvprime.vn

# Slack bot token + channel ID.
# This uses the same Slack API style as pipeline/slack-send-message-wft.yaml:
#   POST https://slack.com/api/chat.postMessage
#   Authorization: Bearer $SLACK_BOT_TOKEN
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_API_URL=https://slack.com/api/chat.postMessage

# Optional default Slack thread permalink or timestamp.
# You can override per run with a full Slack message link:
#   slackmr --thread 'https://cellutionsworkspace.slack.com/archives/C0AUZGJV22E/p1779769367802099'
# or with a timestamp:
#   slackmr --thread 1779769367.802099
SLACK_THREAD=

# Slack thread cache in /tmp. If you pass --thread once, later runs reuse it until TTL expires.
SLACK_THREAD_CACHE_TTL_HOURS=12

# Optional fallback if you prefer Incoming Webhooks instead of bot token.
SLACK_WEBHOOK_URL=

# Selectable Slack reviewers shown by fzf.
# Put a readable name before the mention; the script extracts the <@...> part.
SLACK_REVIEWER_OPTIONS=(
  "Quan <@U06130PCBGC>"
  "Phuoc <@U06858K5T34>"
)
