CONFLUENCE_BASE_URL=https://docs.example.com
CONFLUENCE_EMAIL=your.name@example.com
CONFLUENCE_API_TOKEN=replace_me
CONFLUENCE_AUTH_MODE=basic
# For Confluence Cloud, basic auth usually means email + API token.
# For OAuth or non-Cloud deployments, adjust the auth fields in your integration code.
CONFLUENCE_DEFAULT_SPACE_ID=
CONFLUENCE_DEFAULT_SPACE_KEY=
CONFLUENCE_DEFAULT_PARENT_PAGE_ID=
CONFLUENCE_TIMEOUT_SECONDS=30
